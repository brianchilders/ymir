# Mimir Intent Router — copy to .env and edit

# Upstream services
OLLAMA_URL=http://blackmagic.lan:11434
VERDANDI_URL=http://blackmagic.lan:8901
MUNINN_URL=http://blackmagic.lan:8900

# LLM
MIMIR_LLM_MODEL=llama3.2:3b
MIMIR_LLM_MAX_TOKENS=80
MIMIR_LLM_TEMPERATURE=0.4

# Avatar output (OpenHome relay)
RELAY_HOST=192.168.76.195
RELAY_PORT=8767
AVATAR_ROOMS=living_room,office,kitchen

# Silence rules
SILENCE_COOLDOWN_SECONDS=90
GREETING_COOLDOWN_MINUTES=5

# Service
MIMIR_PORT=8902

# Logging
LOG_LEVEL=INFO
